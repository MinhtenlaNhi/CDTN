PORT=5000
# Atlas: thay USER, PASSWORD (mã hóa URL: @ → %40), cluster và tên DB. Không dùng mật khẩu thật trong file .example — chỉ copy sang server/.env (local) hoặc Render Environment.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/online_course_platform?retryWrites=true&w=majority
JWT_SECRET=replace_with_long_random_string
